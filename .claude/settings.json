{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(chmod:*)",
      "Bash(curl:*)",
      "Bash(gh api:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(lsof:*)",
      "Bash(pip install:*)",
      "Bash(pip:*)",
      "Bash(ps:*)",
      "Bash(python3:*)",
      "Bash(./scripts/dev.sh:*)",
      "WebFetch(domain:github.com)",
      "WebSearch"
    ],
    "deny": [
      "Read(.git/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "BRANCH=$(git -C /Users/Danny_1/Sites/Anarack branch --show-current 2>/dev/null || echo 'detached'); if [ \"$BRANCH\" = \"main\" ]; then echo \"🔴 WARNING: MAIN | Anarack | http://localhost:8080\"; else echo \"branch: $BRANCH | Anarack | http://localhost:8080\"; fi"
  }
}
